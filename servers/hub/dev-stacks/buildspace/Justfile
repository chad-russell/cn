# Buildspace dev stack
# Run from this directory or anywhere: just -f ~/Code/cn/servers/hub/dev-stacks/buildspace/Justfile <recipe>

compose_file := justfile_directory() / "compose.yaml"

# List available recipes (default)
default:
    @just --list

# ── Infrastructure ────────────────────────────────────────────────

# Start postgres
infra-up:
    podman compose -f {{ compose_file }} up -d

# Stop postgres
infra-down:
    podman compose -f {{ compose_file }} down

# Tail postgres logs
infra-logs:
    podman compose -f {{ compose_file }} logs -f

# ── Setup ─────────────────────────────────────────────────────────

# Full bootstrap: start postgres, create role/DB, install deps, migrate + seed
bootstrap:
    systemctl --user start buildspace-bootstrap.service

# Start infra + all app services (primary entry point)
up: infra-up
    systemctl --user start buildspace-stack.target

# Stop all app services
stop:
    systemctl --user stop buildspace-stack.target
