# Hummingbird API host dev environment
# Derived from ~/Gloo/gloo-control-plane/envs/hb-api.env with container DNS → localhost

NODE_ENV=development
APP_ENV=local
PORT=8000

# Database (container DNS "postgres:5432" → "127.0.0.1:5433")
CONN_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres

# S3 (extra_hosts "rustfs.gloo.local" → "127.0.0.1:9000")
AWS_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=rustfsadmin
AWS_S3_SECRET_ACCESS_KEY=rustfsadmin
AWS_S3_BUCKET=storyhub-media-items
AWS_S3_ENDPOINT=http://127.0.0.1:9000
AWS_CLOUDFRONT_URL=http://127.0.0.1:9000/storyhub-media-items
AWS_CLOUDFRONT_KEYPAIR_ID=dummy-keypair-id

# Dev-only placeholder
CLOUDFRONT_KEYPAIR_USER_CONTENT_PRIVATE_KEY="placeholder"
