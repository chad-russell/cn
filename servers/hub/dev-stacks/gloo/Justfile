# Gloo dev stack
# Run from this directory or anywhere: just -f ~/Code/cn/servers/hub/dev-stacks/gloo/Justfile <recipe>

compose_file := justfile_directory() / "compose.yaml"

# List available recipes (default)
default:
    @just --list

# ── Infrastructure ────────────────────────────────────────────────

# Start infra (postgres, rustfs, pgadmin)
infra-up:
    podman compose -f {{ compose_file }} up -d

# Stop infra
infra-down:
    podman compose -f {{ compose_file }} down

# Tail infra logs
infra-logs:
    podman compose -f {{ compose_file }} logs -f

# Create databases in postgres (idempotent)
init-db:
    ./scripts/init-db.sh

# Create S3 buckets in rustfs (idempotent)
init-buckets:
    ./scripts/init-buckets.sh

# First-time infra setup: start + init-db + init-buckets
infra-init: infra-up init-db init-buckets

# ── App services ──────────────────────────────────────────────────

# Install (or refresh) systemd user units from this repo
install-units:
    ./scripts/install-user-units.sh

# Full schema + seed bootstrap (stops app units first)
bootstrap:
    ./scripts/bootstrap-data.sh

# ── Convenience ───────────────────────────────────────────────────

# Render runtime env for a service without starting it
render-env service:
    ./systemd/render-runtime-env.sh {{ service }}
