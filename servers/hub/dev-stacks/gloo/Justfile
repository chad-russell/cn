# Gloo dev stack
# Run from this directory or anywhere: just -f ~/Code/cn/servers/hub/dev-stacks/gloo/Justfile <recipe>

compose_file := justfile_directory() / "compose.yaml"

# List available recipes (default)
default:
    @just --list

# ── Infrastructure ────────────────────────────────────────────────

# Start infra (postgres, rustfs, pgadmin)
infra-up:
    podman compose -f {{ compose_file }} up -d

# Stop infra
infra-down:
    podman compose -f {{ compose_file }} down

# Tail infra logs
infra-logs:
    podman compose -f {{ compose_file }} logs -f

# Create databases in postgres (idempotent)
init-db:
    ./scripts/init-db.sh

# Create S3 buckets in rustfs (idempotent)
init-buckets:
    ./scripts/init-buckets.sh

# First-time infra setup: start + init-db + init-buckets
infra-init: infra-up init-db init-buckets

# ── Bootstrap ─────────────────────────────────────────────────────

# Render runtime env for a service without starting it
render-env service:
    ./scripts/render-runtime-env.sh {{ service }}

# Bootstrap GPL: push schema + seed
bootstrap-gpl: render-env-gpl
    ./scripts/bootstrap-gpl.sh

# Bootstrap Hummingbird API: seed data
bootstrap-hb-api: render-env-hb-api
    ./scripts/bootstrap-hb-api.sh

# Bootstrap Storyhub: seed data
bootstrap-storyhub: render-env-storyhub
    ./scripts/bootstrap-storyhub.sh

# Bootstrap Polymer: push schema + seed
bootstrap-polymer: render-env-polymer
    ./scripts/bootstrap-polymer.sh

# Bootstrap all services (infra up + init-db + render envs + seed each)
bootstrap-all: infra-up init-db render-env-all bootstrap-gpl bootstrap-hb-api bootstrap-storyhub bootstrap-polymer
    @echo "Bootstrap complete."

# ── Render env helpers ────────────────────────────────────────────

render-env-gpl:
    ./scripts/render-runtime-env.sh gpl

render-env-hb-api:
    ./scripts/render-runtime-env.sh hb-api

render-env-storyhub:
    ./scripts/render-runtime-env.sh storyhub

render-env-polymer:
    ./scripts/render-runtime-env.sh polymer

render-env-all: render-env-gpl render-env-hb-api render-env-storyhub render-env-polymer

# ── Convenience ───────────────────────────────────────────────────

# Start infra + all app services (primary entry point)
up: infra-up
    systemctl --user start gloo-all.target

# Stop all app services
stop:
    systemctl --user stop gloo-all.target
