# GPL host dev environment
# Derived from ~/Gloo/gloo-control-plane/envs/gpl.env with container DNS → localhost

NODE_ENV=development
NEXT_PUBLIC_ENABLE_PROJECT_PACKS_PAGE=true

# Database (container DNS "postgres:5432" → "127.0.0.1:5433")
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/gpl_db

# Better Auth
BETTER_AUTH_SECRET=5lcA146cNvFoHENAS8996oRAuX/cCreDKC+h6XOYJrYswZXkbGoMpVrnej2mb9vm
BETTER_AUTH_URL=https://gpl.internal.crussell.io
NEXT_PUBLIC_BETTER_AUTH_URL=https://gpl.internal.crussell.io

# S3 (container DNS "rustfs:9000" → "127.0.0.1:9000")
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET_NAME=gpl-assets
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_FORCE_PATH_STYLE=true

# Hummingbird API (container DNS "hummingbird-api:8000" → "127.0.0.1:8000")
HUMMINGBIRD_API_URL=http://127.0.0.1:8000
HUMMINGBIRD_API_PATH=/api/hummingbird/projects
HUMMINGBIRD_API_KEY=277c4aa3770788d1ad603ab382c5404138aab5acc79f7c61

# Hummingbird SSO (browser — these stay as internal.crussell.io domains)
NEXT_PUBLIC_HUMMINGBIRD_URL=https://hb-web.internal.crussell.io
NEXT_PUBLIC_HUMMINGBIRD_REDIRECT_URI=https://gpl.internal.crussell.io/auth/hummingbird/callback
