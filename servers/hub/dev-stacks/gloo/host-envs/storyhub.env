# Storyhub host dev environment
# Storyhub is a Next.js app in the hummingbird monorepo (workspace: storyhub)

NODE_ENV=development
APP_ENV=local

# Database (host postgres on 5433)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/storyhub"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5433/storyhub"

# Hummingbird connections
HUMMINGBIRD_API_URL="http://127.0.0.1:8000"
HUMMINGBIRD_URL="http://127.0.0.1:3100"
HUMMINGBIRD_INTEGRATION_TOKEN="g360-storyhub-to-hummingbird-bearer-token"

# Storyhub worker (runs locally)
STORYHUB_WORKER_URL="http://127.0.0.1:8001"
STORYHUB_WORKER_BEARER_TOKEN="g360-storyhub-worker-bearer-token"
STORYHUB_STANDALONE="true"

# Session
# SESSION_SECRET loaded from encrypted secrets

# S3 (RustFS on host)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="rustfsadmin"
AWS_SECRET_ACCESS_KEY="rustfsadmin"
S3_ENDPOINT="http://127.0.0.1:9000"
MEDIA_ITEMS_BUCKET="storyhub-media-items"
