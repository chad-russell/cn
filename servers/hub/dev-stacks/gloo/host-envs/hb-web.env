# Hummingbird Web host dev environment
# Derived from ~/Gloo/gloo-control-plane/envs/hb-web.env
# No container DNS references — all browser-facing URLs stay as internal.crussell.io

APP_ENV=local
PORT=3100
API_BASE_URL=https://hb-api.internal.crussell.io
VITE_API_BASE_URL=https://hb-api.internal.crussell.io
STORYHUB_BASE_URL=https://storyhub.internal.crussell.io
ALLOWED_HOSTS=hb-web.internal.crussell.io
