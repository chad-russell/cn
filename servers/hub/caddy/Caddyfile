# Internal services only - *.internal.crussell.io
# Public routes (*.crussell.io) handled by external proxy

*.internal.crussell.io {
    tls {
        dns route53 {
            hosted_zone_id Z0225258330LLQ5BK81Z0
        }
        propagation_timeout 5m
    }

    # Brunch-managed internal routes live under ~/.config/caddy/routes/internal/
    import /etc/caddy/imports/routes/internal/*.caddy

    # --- hub Services (192.168.20.105 / 10.10.0.1) ---
    @linkding host linkding.internal.crussell.io
    handle @linkding {
        reverse_proxy 127.0.0.1:30080
    }

    @papra host papra.internal.crussell.io
    handle @papra {
        reverse_proxy 127.0.0.1:30083
    }

    @ntfy host ntfy.internal.crussell.io
