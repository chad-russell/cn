    admin 127.0.0.1:2020
}

# Internal services only - *.internal.crussell.io
# Public routes (*.crussell.io) handled by external proxy

*.internal.crussell.io {
    tls {
        dns route53 {
            hosted_zone_id Z0225258330LLQ5BK81Z0
        }
        propagation_timeout 5m
    }

    # All internal routes are loaded from individual files.
    # Each file in routes/internal/*.caddy contains matchers and handlers
    # for a logical group of services.
    import /etc/caddy/imports/routes/internal/*.caddy
}

# Public routes - *.crussell.io
*.crussell.io {
    tls {
        dns route53 {
            hosted_zone_id Z0225258330LLQ5BK81Z0
        }
        propagation_timeout 15m
        resolvers 8.8.8.8 1.1.1.1
    }

    @homeassistant host homeassistant.crussell.io
    handle @homeassistant {
        reverse_proxy 192.168.20.51:8123
    }

    @jellyfin host jellyfin.crussell.io
    handle @jellyfin {
        reverse_proxy 192.168.20.61:8096
    }

    @photos host photos.crussell.io
    handle @photos {
        reverse_proxy 127.0.0.1:30093
    }

    @chex-mix-timer host chex-mix-timer.crussell.io
    handle @chex-mix-timer {
        reverse_proxy 192.168.20.64:8732
    }

}
