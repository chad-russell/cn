        reverse_proxy 127.0.0.1:30085
    }

    @searxng host searxng.internal.crussell.io
    handle @searxng {
        reverse_proxy 127.0.0.1:30084
    }

    @openwebui host openwebui.internal.crussell.io
    handle @openwebui {
        reverse_proxy 127.0.0.1:30088
    }

    @adguard host adguard.internal.crussell.io
    handle @adguard {
        reverse_proxy 127.0.0.1:30100 127.0.0.1:30102 {
            lb_policy first
        }
    }

    @openclaw host openclaw.internal.crussell.io
    handle @openclaw {
        redir / /control permanent
        reverse_proxy 127.0.0.1:30110
    }

    # --- k1 Services (192.168.20.61) ---
