const aiHostConfig: BrunchConfig = {
  files: {
    "Code/config.yaml": llamaSwapConfig,
  },
  systemdUnits: {
    user: {
      services: {
        "llama-swap": {
          description: "LLaMA Swap Service",
          after: ["network.target"],
          conditionPathExists: ["%h/Code/llama-swap"],
          enabled: true,
          serviceConfig: {
            execStart: "%h/Code/llama-swap -listen 0.0.0.0:8000",
            workingDirectory: "%h/Code",
            type: "simple",
            restart: "always",
            restartSec: 5,
          },
        },
      },
    },
  },
};

export const aiBrunchConfig: BrunchConfig = mergeBrunch(
  commonBrunchConfig,
  aiHostConfig,
);
