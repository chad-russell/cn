import { mergeBrunch, BrunchConfig } from "brunch";
import { commonBrunchConfig } from "../../profiles/common.bri";
import { brunchConfig as backupConfig } from "./backup.bri";
import { brunchConfig as devStacksConfig } from "./dev-stacks.bri";
import { brunchConfig as healthcheckConfig } from "./healthcheck.bri";

// Hub-specific agent skills for dev stack hosting
const glooHostingSkill = Brioche.includeDirectory("../../agents/skills/gloo-hosting");
const buildspaceHostingSkill = Brioche.includeDirectory("../../agents/skills/buildspace-hosting");

const hubAgentSkillsConfig: BrunchConfig = {
  files: {
    ".agents/skills/gloo-hosting": glooHostingSkill,
    ".agents/skills/buildspace-hosting": buildspaceHostingSkill,
  },
};

export const hubBrunchConfig: BrunchConfig = mergeBrunch(
  commonBrunchConfig,
  backupConfig,
  devStacksConfig,
  healthcheckConfig,
  hubAgentSkillsConfig,
);
