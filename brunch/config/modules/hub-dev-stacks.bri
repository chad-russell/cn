          serviceConfig: {
            execStart: glooRunnable("storyhub", "exec npx next dev --port 3007"),
            type: "simple",
            restart: "on-failure",
            restartSec: 2,
            workingDirectory: "/var/home/crussell/Gloo/360-hummingbird/storyhub",
          },
        },
        "gloo-storyhub-worker": {
