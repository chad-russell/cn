          description: "Gloo Hummingbird dev stack",
          wants: ["gloo-hb-api.service", "gloo-hb-web.service"],
        },
        "gloo-storyhub": {
          description: "Gloo Storyhub dev stack",
          wants: ["gloo-storyhub.service", "gloo-storyhub-worker.service"],
        },
        "buildspace-infra": {
          description: "Buildspace shared infra",
        },
        "buildspace-stack": {
          description: "Buildspace local app stack",
          wants: [
            "buildspace-infra.target",
            "buildspace-deps.service",
            "buildspace-marketplace.service",
            "buildspace-login.service",
            "buildspace-runtime.service",
            "buildspace-studio.service",
            "buildspace-docs.service",
            "buildspace-super-admin.service",
            "buildspace-jobs.service",
          ],
          after: ["buildspace-infra.target", "buildspace-deps.service"],
          propagatesStopTo: [
            "buildspace-marketplace.service",
            "buildspace-login.service",
            "buildspace-runtime.service",
            "buildspace-studio.service",
            "buildspace-docs.service",
            "buildspace-super-admin.service",
            "buildspace-jobs.service",
          ],
        },
        "buildspace": {
          description: "All Buildspace services",
          wants: ["buildspace-stack.target"],
          after: ["buildspace-stack.target"],
        },
      },

      services: {
        // ── Gloo infra services ──
        "gloo-infra-up": {
          description: "Start Gloo compose infra and wait for postgres",
          serviceConfig: {
            execStart: glooInfraUp,
            type: "oneshot",
            remainAfterExit: true,
          },
        },
        "gloo-init-db": {
          description: "Create Gloo databases (idempotent)",
          after: ["gloo-infra-up.service"],
          wants: ["gloo-infra-up.service"],
          serviceConfig: {
            execStart: glooInitDb,
            type: "oneshot",
          },
        },
        "gloo-init-buckets": {
          description: "Create Gloo S3 buckets in RustFS (idempotent)",
          after: ["gloo-infra-up.service"],
          wants: ["gloo-infra-up.service"],
          serviceConfig: {
            execStart: glooInitBuckets,
            type: "oneshot",
            timeoutStartSec: "5min",
          },
        },

        // ── Gloo app services (runnables) ──
        "gloo-gpl": {
          description: "Gloo GPL dev server",
          after: ["network-online.target", "gloo-infra.target"],
          wants: ["network-online.target"],
          serviceConfig: {
            execStart: glooRunnable("gpl", "exec npx next dev -p 3106"),
            type: "simple",
            restart: "on-failure",
            restartSec: 2,
            workingDirectory: "/var/home/crussell/Gloo/360-gpl",
          },
        },
        "gloo-hb-api": {
          description: "Gloo Hummingbird API dev server",
          after: ["network-online.target", "gloo-infra.target"],
          wants: ["network-online.target"],
          partOf: ["gloo-hummingbird.target"],
          serviceConfig: {
            execStart: glooRunnable("hb-api", "exec pnpm --filter api dev"),
            type: "simple",
            restart: "on-failure",
            restartSec: 2,
            workingDirectory: "/var/home/crussell/Gloo/360-hummingbird",
          },
        },
        "gloo-hb-web": {
          description: "Gloo Hummingbird Web dev server",
          after: ["network-online.target", "gloo-infra.target"],
          wants: ["network-online.target"],
          partOf: ["gloo-hummingbird.target"],
          serviceConfig: {
            execStart: glooRunnable("hb-web", "exec pnpm --filter web dev -- --host 0.0.0.0 --port 3100"),
            type: "simple",
            restart: "on-failure",
            restartSec: 2,
            workingDirectory: "/var/home/crussell/Gloo/360-hummingbird",
          },
        },
        "gloo-polymer": {
          description: "Gloo Polymer dev server",
          after: ["network-online.target", "gloo-infra.target"],
          wants: ["network-online.target"],
          serviceConfig: {
            execStart: glooRunnable("polymer", "rm -f .next/dev/lock && exec pnpm exec next dev --turbo --hostname 0.0.0.0 --port 3001"),
            type: "simple",
            restart: "on-failure",
            restartSec: 2,
            workingDirectory: "/var/home/crussell/Gloo/360-polymer/apps/polymer",
