        },
        "buildspace-bootstrap": {
          description: "Bootstrap Buildspace: start postgres, create role/DB, install deps, migrate + seed",
          conditionPathExists: bsConditions,
          serviceConfig: {
            execStart: bsBootstrapRun,
            type: "oneshot",
            workingDirectory: "%h/Code/bs/buildspace",
            environmentFile: "%h/.config/systemd/user/buildspace-overrides.env",
            timeoutStartSec: "30min",
          },
        },
        "buildspace-marketplace": buildspaceAppService(
          "buildspace-marketplace",
          "Buildspace marketplace app",
          "@buildspace/marketplace",
        ),
        "buildspace-login": buildspaceAppService(
          "buildspace-login",
