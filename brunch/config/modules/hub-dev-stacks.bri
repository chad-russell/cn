          "@buildspace/login",
        ),
        "buildspace-runtime": buildspaceAppService(
          "buildspace-runtime",
          "Buildspace runtime app",
          "@buildspace/runtime",
        ),
        "buildspace-studio": buildspaceAppService(
          "buildspace-studio",
          "Buildspace studio app",
          "@buildspace/studio",
        ),
        "buildspace-docs": buildspaceAppService(
