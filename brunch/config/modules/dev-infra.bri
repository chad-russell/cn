import { BrunchConfig } from "brunch";

const devNetworkQuadlet = Brioche.includeFile("./dev-infra/dev.network");
const devPostgresDataVolume = Brioche.includeFile("./dev-infra/dev-postgres-data.volume");
const devPostgresQuadlet = Brioche.includeFile("./dev-infra/dev-postgres.container");

export const devInfraBrunchConfig: BrunchConfig = {
  files: {
    ".config/containers/systemd/dev.network": devNetworkQuadlet,
    ".config/containers/systemd/dev-postgres-data.volume": devPostgresDataVolume,
    ".config/containers/systemd/dev-postgres.container": devPostgresQuadlet,
  },
};
