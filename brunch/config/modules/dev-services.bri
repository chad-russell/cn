export function makeStackEntrypointService(
  description: string,
  memberServices: string[],
) {
  return {
    description,
    wants: memberServices,
    after: memberServices,
    serviceConfig: {
      execStart: "/usr/bin/true",
      type: "oneshot" as const,
      remainAfterExit: true,
    },
  };
}

export function withStackMembership<T extends { partOf?: string[] }>(
  config: T,
  stackName: string,
) {
  return {
    ...config,
    partOf: [...(config.partOf ?? []), `${stackName}.service`],
  };
}
