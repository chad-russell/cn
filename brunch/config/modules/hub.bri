import { brunchConfig as nvimConfig } from "./nvim.bri";
import { brunchConfig as opencodeConfig } from "../opencode.bri";

export const hubBrunchConfig: BrunchConfig = mergeBrunch(
  shellConfig,
  nvimConfig,
  opencodeConfig,
);
