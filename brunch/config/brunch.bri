import { makeBrunch } from "brunch";
import { thinkpadBrunchConfig } from "./modules/thinkpad.bri";
import { hubBrunchConfig } from "./modules/hub.bri";

export const thinkpad = makeBrunch(thinkpadBrunchConfig);

export const hub = makeBrunch(hubBrunchConfig);

// Default export is intentionally empty — always specify a target:
//   brunch apply ./config --target hub
//   brunch apply ./config --target thinkpad
export default makeBrunch({});
