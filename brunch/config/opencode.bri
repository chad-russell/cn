import * as std from "std";
import { BrunchConfig, makeWebAppExecutable } from "brunch";

const opencodeIcon = Brioche.includeFile("./static/opencode-logo-dark.svg");

const opencodeWebRunnable = std.bashRunnable`
  exec /home/linuxbrew/.linuxbrew/bin/opencode web --hostname 0.0.0.0
  `;

export const brunchConfig: BrunchConfig = {
  desktopApps: [
    {
      name: "opencode-desktop",
      executable: makeWebAppExecutable("http://localhost:4096"),
      icon: opencodeIcon,
      iconExt: "svg",
      comment: "Interactive CLI tool for software engineering",
      categories: ["Development"],
    },
  ],
  systemdUnits: {
    user: {
      services: {
        "opencode-web": {
          description: "OpenCode Web Server",
          after: ["network.target"],
          serviceConfig: {
            execStart: opencodeWebRunnable,
            type: "simple",
            restart: "always",
            restartSec: 5,
            workingDirectory: "%h",
          },
        },
      },
    },
  },
};
