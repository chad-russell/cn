# Default Zsh configuration for server

# History settings
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY

# Basic completion
autoload -Uz compinit
compinit

# Better prompt with host info (useful for remote sessions)
PS1='%n@%m:%~%# '

# Useful aliases
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias ...='cd ../..'

# Modern replacements (if installed via brew)
# alias cat='bat --paging=never'
# alias grep='rg'
# alias find='fd'
# alias ls='eza'

# Container aliases
alias p='podman'
alias pc='podman-compose'
alias dps='podman ps'
alias dpsa='podman ps -a'
alias plog='podman logs -f'
alias pimg='podman images'

# Quick system info
alias mem='free -h'
alias disk='df -h'
alias ports='ss -tulpn'
alias myip='curl -s ifconfig.me'
