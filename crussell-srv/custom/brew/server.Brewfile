# Server tools Brewfile
# Install with: brew bundle --file /usr/share/ublue-os/homebrew/server.Brewfile

# Modern replacements for common tools
brew "bat"
brew "eza"
brew "fd"
brew "ripgrep"
brew "du-dust"
brew "procs"
brew "bottom"

# JSON/YAML processing
brew "jq"
brew "yq"

# Network tools
brew "httpie"
brew "doggo"

# Git tools
brew "lazygit"
brew "tig"

# Development
brew "just"
brew "shellcheck"
brew "shfmt"
